# Banco de dados (Railway fornece via ${{Postgres.DATABASE_URL}})
DATABASE_URL=postgresql://user:pass@host:5432/membresia

# JWT — gere um segredo forte:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_segredo_forte_64_chars

# Porta (Railway define automaticamente)
PORT=3031

# CORS — domínios permitidos (separe por vírgula)
CORS_ORIGINS=https://sistema-membresia.pages.dev,https://seu-dominio.com

# E-mail (SMTP para credenciais e reset de senha)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=senha_de_app_do_gmail
EMAIL_FROM="Sistema Membresia <seu@email.com>"

# URL base do frontend (usada nos links dos e-mails)
BASE_URL=https://sistema-membresia.pages.dev

# Evolution API (WhatsApp — opcional)
EVOLUTION_API_URL=https://sua-evolution.com
EVOLUTION_INSTANCE=nome-da-instancia
EVOLUTION_API_KEY=sua-chave
